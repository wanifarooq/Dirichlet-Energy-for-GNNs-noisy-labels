@article{eldan2017braess,
author = {Eldan, Ronen and Rácz, Miklós Z. and Schramm, Tselil},
title = {Braess's paradox for the spectral gap in random graphs and delocalization of eigenvectors},
journal = {Random Structures \& Algorithms},
volume = {50},
number = {4},
pages = {584-611},
keywords = {random graphs, spectral gap, Braess's paradox, graph Laplacian},
doi = {https://doi.org/10.1002/rsa.20696},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/rsa.20696},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/rsa.20696},
abstract = {ABSTRACT We study how the spectral gap of the normalized Laplacian of a random graph changes when an edge is added to or removed from the graph. There are known examples of graphs where, perhaps counter-intuitively, adding an edge can decrease the spectral gap, a phenomenon that is analogous to Braess's paradox in traffic networks. We show that this is often the case in random graphs in a strong sense. More precisely, we show that for typical instances of Erdős-Rényi random graphs G(n, p) with constant edge density , the addition of a random edge will decrease the spectral gap with positive probability, strictly bounded away from zero. To do this, we prove a new delocalization result for eigenvectors of the Laplacian of G(n, p), which might be of independent interest. © 2016 Wiley Periodicals, Inc. Random Struct. Alg., 50, 584–611, 2017},
year = {2017}
}

